:root {
	--space-scale: {{ settings.theme.theme_layout.space_scale or "100" }};
	--color-text: {{ settings.theme.theme_colors.text or "#111111" }};
  --color-link: {{ settings.theme.theme_colors.link or "#111111" }};
	--color-background: {{ settings.theme.theme_colors.background or "#fcfcfc" }};
  --font-weight: 400;
  --font-scale: {{ settings.theme.theme_typography.font_scale or "100" }};
	--line-height-scale: {{ settings.theme.theme_typography.line_height_scale or "100" }};
	--link-underline: {{ "underline" if settings.theme.theme_typography.link_underline else "none" }};
  --transition-time: {{ settings.theme.theme_features.transition_duration or "300" }}ms;
  --font-serif: "Iowan Old Style", "Palatino Linotype", "URW Palladio L", P052, serif;

  /* Button Colors - Transparent/Outlined aesthetic */
  --color-button-bg: var(--color-background);
  --color-button-text: var(--color-text);
}

:root[dark] {
	--color-text: {{ settings.theme.theme_colors.text_dark or "#fcfcfc" }};
  --color-link: {{ settings.theme.theme_colors.link_dark or "#fcfcfc" }};
	--color-background: {{ settings.theme.theme_colors.background_dark or "#111111" }};
}