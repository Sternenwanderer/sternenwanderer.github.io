<footer class="p--2 text--small">
  <div style="text-align: center; margin-bottom: 2rem;">
    <img src="/icon_transparent.svg" alt="Sternenwanderer Logo" class="footer-logo" style="width: 64px; height: 64px; margin: 0 auto;">
  </div>
	<div class="grid grid--footer">

    <div class="grid__item">
      <span>&copy; {{ settings.metadata.site_title or "Site Title" }}</span>
    </div>

    {% if settings.metadata.site_email %}
      <div class="grid__item">
        <span>
          <a href="mailto:{{ settings.metadata.site_email }}">{{ settings.metadata.site_email }}</a>
        </span>
      </div>
    {% endif %}

    {% if settings.metadata.site_social_url %}
      <div class="grid__item">
        <span>
          <a href="{{ settings.metadata.site_social_url }}" target="_blank" rel="noopener">{{ settings.i18n.site_social_title }}</a>
        </span>
      </div>
    {% endif %}

      <div class="grid__item">
        <a href="{{ settings.metadata.site_about_url }}" target="_blank"> {{ settings.i18n.site_about_title }} </a>
      </div>

  </div>

</footer>
